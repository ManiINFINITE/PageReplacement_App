<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRA.GUI.App"
             xmlns:local="using:PRA.GUI"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://PRA.GUI/Styles/BordersStyles.axaml" />
        <StyleInclude Source="avares://PRA.GUI/Styles/TextBlocksStyles.axaml" />
        <StyleInclude Source="avares://PRA.GUI/Styles/ButtonsStyles.axaml" />
        <StyleInclude Source="avares://PRA.GUI/Styles/InputsStyles.axaml" />
        <StyleInclude Source="avares://PRA.GUI/Styles/ProgressStyles.axaml" />
        <StyleInclude Source="avares://PRA.GUI/Styles/SidebarStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>

            <!-- COMMON RESOURCES (Shared between both themes) -->
            <!-- Accent Colors - Kept the same for brand consistency -->
            <Color x:Key="COLOR_FireOpal">#EF6448</Color>
            <Color x:Key="COLOR_MintGreen">#5FD98A</Color>
            <Color x:Key="COLOR_Crimson">#F0455A</Color>
            <Color x:Key="COLOR_Amber">#F2C14E</Color>
            <Color x:Key="COLOR_Sky">#5AC8FA</Color>

            <!-- Accent Brushes -->
            <SolidColorBrush x:Key="BRUSH_FireOpal" Color="{StaticResource COLOR_FireOpal}" />
            <SolidColorBrush x:Key="BRUSH_MintGreen" Color="{StaticResource COLOR_MintGreen}" />
            <SolidColorBrush x:Key="BRUSH_Crimson" Color="{StaticResource COLOR_Crimson}" />
            <SolidColorBrush x:Key="BRUSH_Amber" Color="{StaticResource COLOR_Amber}" />
            <SolidColorBrush x:Key="BRUSH_Sky" Color="{StaticResource COLOR_Sky}" />

            <!-- Fonts -->
            <FontFamily x:Key="Nunito-Regular">Assets/Fonts/Nunito-Regular.ttf#Nunito Regular</FontFamily>
            <FontFamily x:Key="Nunito-SemiBold">Assets/Fonts/Nunito-SemiBold.ttf#Nunito SemiBold</FontFamily>
            <FontFamily x:Key="Nunito-Bold">Assets/Fonts/Nunito-Bold.ttf#Nunito Bold</FontFamily>
            <FontFamily x:Key="Nunito-ExtraBold">Assets/Fonts/Nunito-ExtraBold.ttf#Nunito ExtraBold</FontFamily>

            <!-- Icons -->
            <FontFamily x:Key="Phosphor-Bold">Assets/Fonts/Phosphor-Bold.ttf#Phosphor-Bold</FontFamily>

            <ResourceDictionary.ThemeDictionaries>

                <!-- LIGHT THEME -->
                <ResourceDictionary x:Key="Light">
                    <!-- Base - Lightened versions -->
                    <Color x:Key="COLOR_RaisinBlack">#E8E9E8</Color>
                    <Color x:Key="COLOR_Jet">#D4D6D5</Color>
                    <Color x:Key="COLOR_SmokyBlack">#F0F0EF</Color>
                    <Color x:Key="COLOR_Ash">#C5C8C6</Color>

                    <!-- Muted Accents - Light theme variants -->
                    <Color x:Key="COLOR_FireOpalMuted">#F5CCC5</Color>
                    <Color x:Key="COLOR_MintGreenMuted">#B6F5BD</Color>
                    <Color x:Key="COLOR_CrimsonMuted">#F5D0CC</Color>
                    <Color x:Key="COLOR_AmberMuted">#F0F5C7</Color>

                    <!-- Text - Inverted for light background -->
                    <Color x:Key="COLOR_TextPrimary">#1A1C1B</Color>
                    <Color x:Key="COLOR_TextSecondary">#6A6D6B</Color>
                    <Color x:Key="COLOR_TextDisabled">#A5A8A6</Color>

                    <!-- Base Brushes -->
                    <SolidColorBrush x:Key="BRUSH_RaisinBlack" Color="{StaticResource COLOR_RaisinBlack}" />
                    <SolidColorBrush x:Key="BRUSH_Jet" Color="{StaticResource COLOR_Jet}" />
                    <SolidColorBrush x:Key="BRUSH_SmokyBlack" Color="{StaticResource COLOR_SmokyBlack}" />
                    <SolidColorBrush x:Key="BRUSH_Ash" Color="{StaticResource COLOR_Ash}" />

                    <!-- Muted Accent Brushes -->
                    <SolidColorBrush x:Key="BRUSH_FireOpalMuted" Color="{StaticResource COLOR_FireOpalMuted}" />
                    <SolidColorBrush x:Key="BRUSH_MintGreenMuted" Color="{StaticResource COLOR_MintGreenMuted}" />
                    <SolidColorBrush x:Key="BRUSH_CrimsonMuted" Color="{StaticResource COLOR_CrimsonMuted}" />
                    <SolidColorBrush x:Key="BRUSH_AmberMuted" Color="{StaticResource COLOR_AmberMuted}" />

                    <!-- Text Brushes -->
                    <SolidColorBrush x:Key="BRUSH_TextPrimary" Color="{StaticResource COLOR_TextPrimary}" />
                    <SolidColorBrush x:Key="BRUSH_TextSecondary" Color="{StaticResource COLOR_TextSecondary}" />
                    <SolidColorBrush x:Key="BRUSH_TextDisabled" Color="{StaticResource COLOR_TextDisabled}" />
                </ResourceDictionary>

                <!-- DARK THEME -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Base -->
                    <Color x:Key="COLOR_RaisinBlack">#202322</Color>
                    <Color x:Key="COLOR_Jet">#2B2E2D</Color>
                    <Color x:Key="COLOR_SmokyBlack">#141615</Color>
                    <Color x:Key="COLOR_Ash">#3A3D3B</Color>

                    <!-- Muted Accents - Dark theme variants -->
                    <Color x:Key="COLOR_FireOpalMuted">#774032</Color>
                    <Color x:Key="COLOR_MintGreenMuted">#256742</Color>
                    <Color x:Key="COLOR_CrimsonMuted">#3A1F24</Color>
                    <Color x:Key="COLOR_AmberMuted">#3A331E</Color>

                    <!-- Text -->
                    <Color x:Key="COLOR_TextPrimary">#F4F4F2</Color>
                    <Color x:Key="COLOR_TextSecondary">#9A9D9B</Color>
                    <Color x:Key="COLOR_TextDisabled">#5A5D5B</Color>

                    <!-- Base Brushes -->
                    <SolidColorBrush x:Key="BRUSH_RaisinBlack" Color="{StaticResource COLOR_RaisinBlack}" />
                    <SolidColorBrush x:Key="BRUSH_Jet" Color="{StaticResource COLOR_Jet}" />
                    <SolidColorBrush x:Key="BRUSH_SmokyBlack" Color="{StaticResource COLOR_SmokyBlack}" />
                    <SolidColorBrush x:Key="BRUSH_Ash" Color="{StaticResource COLOR_Ash}" />

                    <!-- Muted Accent Brushes -->
                    <SolidColorBrush x:Key="BRUSH_FireOpalMuted" Color="{StaticResource COLOR_FireOpalMuted}" />
                    <SolidColorBrush x:Key="BRUSH_MintGreenMuted" Color="{StaticResource COLOR_MintGreenMuted}" />
                    <SolidColorBrush x:Key="BRUSH_CrimsonMuted" Color="{StaticResource COLOR_CrimsonMuted}" />
                    <SolidColorBrush x:Key="BRUSH_AmberMuted" Color="{StaticResource COLOR_AmberMuted}" />

                    <!-- Text Brushes -->
                    <SolidColorBrush x:Key="BRUSH_TextPrimary" Color="{StaticResource COLOR_TextPrimary}" />
                    <SolidColorBrush x:Key="BRUSH_TextSecondary" Color="{StaticResource COLOR_TextSecondary}" />
                    <SolidColorBrush x:Key="BRUSH_TextDisabled" Color="{StaticResource COLOR_TextDisabled}" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>