<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:PRA.GUI.ViewModels"
        xmlns:services="clr-namespace:PRA.GUI.Services"
        xmlns:converters="clr-namespace:PRA.GUI.Converters"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="PRA.GUI.Views.MainWindowView"
        x:DataType="viewModels:MainWindowViewModel"
        Background="{StaticResource BRUSH_RaisinBlack}"
        Icon="/Assets/Icons/icon.png"
        Title="Page Replacement Simulator"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="640"
        WindowState="Maximized">

    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="Auto,*" Background="{DynamicResource COLOR_RaisinBlack}">

        <!-- ===================== SIDEBAR ===================== -->
        <Border Grid.Column="0" Classes="Sidebar" Classes.Collapsed="{Binding IsSidebarCollapsed}">
            <Grid RowDefinitions="Auto,Auto,*,Auto, Auto">

                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,8,8,24">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="PRA" Classes="H2" Foreground="{StaticResource BRUSH_FireOpal}" />
                        <TextBlock Text="Page Replacement Sim" Classes="Caption Collapsible" />
                    </StackPanel>
                </Grid>

                <Button Grid.Row="1" Classes="Primary"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Margin="0,0,0,20"
                        Command="{Binding OpenNewSimulationCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Classes="PlusIcon Collapsed" Text="+" FontWeight="ExtraBold" FontSize="20"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="New Simulation" Classes="Collapsible" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="2" Spacing="2">
                    <Button Classes="NavItem"
                            Command="{Binding Navigation.NavigateCommand}"
                            CommandParameter="{x:Static services:AppPage.Dashboard}"
                            Classes.Active="{Binding Navigation.CurrentPage, Converter={x:Static converters:EnumEqualsConverter.Instance}, ConverterParameter={x:Static services:AppPage.Dashboard}}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Classes="NavIcon">
                                <TextBlock Text="&#xE2C2;" />
                            </Border>
                            <TextBlock Text="Dashboard" Classes="Collapsible" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="NavItem"
                            Command="{Binding Navigation.NavigateCommand}"
                            CommandParameter="{x:Static services:AppPage.CompareAll}"
                            Classes.Active="{Binding Navigation.CurrentPage, Converter={x:Static converters:EnumEqualsConverter.Instance}, ConverterParameter={x:Static services:AppPage.CompareAll}}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Classes="NavIcon">
                                <TextBlock Text="&#xE190;" />
                            </Border>
                            <TextBlock Text="Compare All" Classes="Collapsible" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="NavItem"
                            Command="{Binding Navigation.NavigateCommand}"
                            CommandParameter="{x:Static services:AppPage.CompareTwo}"
                            Classes.Active="{Binding Navigation.CurrentPage, Converter={x:Static converters:EnumEqualsConverter.Instance}, ConverterParameter={x:Static services:AppPage.CompareTwo}}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Classes="NavIcon">
                                <TextBlock Text="&#xE27C;" />
                            </Border>
                            <TextBlock Text="Compare Two" Classes="Collapsible" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" Margin="0 0 0 15">
                    <Button Classes="ThemeToggle" VerticalAlignment="Center"
                            Content="{Binding ThemeIcon}" FontFamily="{DynamicResource Phosphor-Bold}"
                            Command="{Binding ToggleThemeCommand}" />
                    <TextBlock Text="Toggle Text" FontFamily="{DynamicResource Nunito-SemiBold}"
                               VerticalAlignment="Center" Classes="Collapsible" />
                </StackPanel>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12">
                    <Button Classes="SidebarToggle" VerticalAlignment="Center"
                            Command="{Binding ToggleSidebarCommand}"
                            Content="{Binding IsSidebarCollapsed, Converter={x:Static converters:CollapsedChevronConverter.Instance}}"
                            FontFamily="{DynamicResource Phosphor-Bold}" />
                    <TextBlock Text="{Binding CollapseText}" FontFamily="{DynamicResource Nunito-SemiBold}"
                               VerticalAlignment="Center" Classes="Collapsible" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ===================== MAIN ===================== -->
        <Grid Grid.Column="1" Margin="32">
            <ContentControl Content="{Binding Navigation.CurrentViewModel}" />
        </Grid>

        <!-- ===================== OVERLAY ===================== -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Classes="Scrim" IsVisible="{Binding Overlay.IsVisible}">
            <ContentControl Content="{Binding Overlay.CurrentViewModel}" />
        </Border>

    </Grid>

</Window>