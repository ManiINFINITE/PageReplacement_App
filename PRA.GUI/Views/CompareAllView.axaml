<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:PRA.GUI.ViewModels"
             x:Class="PRA.GUI.Views.CompareAllView"
             x:DataType="viewModels:CompareAllViewModel">

    <Border Classes="Card Elevated" VerticalAlignment="Top" Padding="24">
        <StackPanel Spacing="8">
            <TextBlock Text="{Binding Title}" Classes="H1"/>
            <TextBlock Text="{Binding Description}" Classes="Body"/>
        </StackPanel>
    </Border>

</UserControl>
